makeSection("TRAIN LOCATION", 195, 8)

-- ↓ CHANGE TRAIN ZONES HERE
local trainPositions = {
    ["2x Power"]  = CFrame.new(9.508988380432129,   4.683034420013428, -34.22232437133789),
    ["5x Power"]  = CFrame.new(-12.534440040588379, 5.009988784790039, -39.04243850708008),
    ["10x Power"] = CFrame.new(29.299985885620117,  4.683034896850586, -59.210044860839844),
    ["50x Power"] = CFrame.new(6.380734920501709,   4.683034420013428, -55.88126754760742),
}
local trainOrder = {"2x Power", "5x Power", "10x Power", "50x Power"}
-- ↑ CHANGE TRAIN ZONES HERE

local trainLoop = nil
local activeTrainBtn = nil
local trainBtns = {}

local trainGridPos = {
    {195, 24}, {280, 24},
    {195, 50}, {280, 50},
}

for i, name in ipairs(trainOrder) do
    local px = trainGridPos[i][1]
    local py = trainGridPos[i][2]

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 78, 0, 20)
    btn.Position = UDim2.new(0, px, 0, py)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.BorderSizePixel = 0
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(160, 160, 160)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 9
    btn.Parent = content
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
    trainBtns[name] = btn

    btn.MouseButton1Click:Connect(function()
        if activeTrainBtn == btn then
            btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            btn.TextColor3 = Color3.fromRGB(160, 160, 160)
            if trainLoop then trainLoop:Disconnect(); trainLoop = nil end
            activeTrainBtn = nil
        else
            for _, b in pairs(trainBtns) do
                b.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                b.TextColor3 = Color3.fromRGB(160, 160, 160)
            end
            btn.BackgroundColor3 = Color3.fromRGB(0, 150, 60)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            activeTrainBtn = btn
            if trainLoop then trainLoop:Disconnect(); trainLoop = nil end
            local cf = trainPositions[name]

            task.spawn(function()
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local humanoid = char:FindFirstChildOfClass("Humanoid")
                    if humanoid then humanoid.WalkSpeed = 0 end
                    task.wait(0.05)
                    char.HumanoidRootPart.CFrame = cf
                    task.wait(0.05)
                    if humanoid then humanoid.WalkSpeed = 16 end
                end
                -- Deselect button after tp
                btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                btn.TextColor3 = Color3.fromRGB(160, 160, 160)
                activeTrainBtn = nil
            end)
        end
    end)
end

