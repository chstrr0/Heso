-- Helpers
local function makeSection(text, x, y)
    local s = Instance.new("TextLabel")
    s.Size = UDim2.new(0, 160, 0, 13)
    s.Position = UDim2.new(0, x, 0, y)
    s.BackgroundTransparency = 1
    s.Text = text
    s.TextColor3 = Color3.fromRGB(110, 110, 110)
    s.Font = Enum.Font.GothamBold
    s.TextSize = 9
    s.TextXAlignment = Enum.TextXAlignment.Left
    s.Parent = content
end

local function makeToggle(labelText, x, y, callback)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 105, 0, 22)
    label.Position = UDim2.new(0, x, 0, y)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(190, 190, 190)
    label.Font = Enum.Font.Gotham
    label.TextSize = 10
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = content

    local switchBg = Instance.new("Frame")
    switchBg.Size = UDim2.new(0, 40, 0, 20)
    switchBg.Position = UDim2.new(0, x + 108, 0, y + 1)
    switchBg.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    switchBg.BorderSizePixel = 0
    switchBg.Parent = content
    Instance.new("UICorner", switchBg).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(0, 3, 0.5, -7)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Parent = switchBg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = switchBg

    local isOn = false
    btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        if isOn then
            switchBg.BackgroundColor3 = Color3.fromRGB(0, 190, 75)
            knob:TweenPosition(UDim2.new(0, 23, 0.5, -7), "Out", "Quad", 0.15, true)
        else
            switchBg.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            knob:TweenPosition(UDim2.new(0, 3, 0.5, -7), "Out", "Quad", 0.15, true)
        end
        callback(isOn)
    end)
end

